        <p id="demo"></p>
        <script>
            const id = new WeakMap();

            class Student {
                constructor(name) {
                    id.set(this, {secret: "hidden info"});
                    this.name = name;
                }
                getSecret() {
                    return id.get(this).secret;
                }
            }

            const student1 = new Student("John");
            const student2 = new Student("Paul");

            secret1 = student1.getSecret();
            secret2 = student2.getSecret();

            document.getElementById("demo").innerHTML = "Student 1 secret: " + secret1 + "<br>" + "Student 2 secret: " + secret2;
